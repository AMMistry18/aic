<mujoco model="Scene">
  <!--
    Physics tuning for Gazebo (Bullet-Featherstone) behavioral match:
    - integrator="euler": Semi-implicit Euler matches Bullet's integration scheme.
      "implicitfast" adds implicit Coriolis/damping treatment that Bullet doesn't have,
      causing numerical damping differences.
    - solver="Newton": High-accuracy constraint solver.
    - iterations/tolerance: Tight solver for accurate force resolution.
    - timestep="0.002": Matches Gazebo's 2ms step (500 Hz physics).
  -->
  <option integrator="euler" timestep="0.002" solver="Newton" iterations="100" tolerance="1e-10"/>
  <include file="aic_robot.xml"/>
  <include file="aic_world.xml"/>
</mujoco>